# Root Environment Variables
# Used by the backend service. Copy this file to .env and fill in your values.
# Get keys from: Supabase Dashboard → Settings → API

# Frontend keys (anon — safe for browser, also used by frontend/.env)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend keys (service_role — server-side only, bypasses RLS)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional
NODE_ENV=development
PORT=3000

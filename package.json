{
    "name": "adaptiq",
    "private": true,
    "version": "1.0.0",
    "description": "AdaptIQ — Adaptive learning platform with ML-powered quiz engine",
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && npm run dev",
        "dev:ml": "cd ml-service && .\\venv\\Scripts\\activate && uvicorn app.main:app --reload --port 8000",
        "test:backend": "cd backend && npm test",
        "test:ml": "cd ml-service && .\\venv\\Scripts\\python -m pytest tests/ -v",
        "install:all": "cd frontend && npm install && cd ../backend && npm install",
        "build": "cd frontend && npm run build"
    }
}
